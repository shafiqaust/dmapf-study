% #program plan(i).
% #external query(i).
% 1 { cross(A2,i-1) : link(A1,A2) } 1 :- inn(A1,i-1).
% inn(A,i) :- inn(_,i-1), cross(A,i-1).

% reached(i) :- robot(R), target(R,A), inn(A,i).
% :- query(i), not reached(i).

