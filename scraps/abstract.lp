#program plan(i).
#external query(i).
1 { in(A2,i) : link(A1,A2) } 1 :- in(A1,i-1).
% { in(A2,i) : link(A1,A2) } :- in(A1,i-1).
% :- in(A1,i), in(A2,i), A1 != A2.

% reached(i) :- target(A), in(A,i).
% :- query(i), not reached(i).
:- target(A), not in(A,i), query(i).

% 10.20 s
#show in/2.

% #show.
% #show (A,I) : in(A,I).

