#external l(5,2,10).
#external l(5,4,10).
#external l(5,6,10).
#external l(5,8,10).

0 { a(R,N2,N3,|X1-X2|+|Y1-Y2|) : link(_,A1,A2,N2,N3), node(N1,(X1,Y1),_), node(N2,(X2,Y2),_) } 1 :- m(R,N1,A1,A2), l(A1,A2,_).
% { a(R,N2,N3,D) : link(_,A1,A2,N2,N3), node(N1,(X1,Y1),_), node(N2,(X2,Y2),_), D = |X1-X2|+|Y1-Y2| } :- m(R,N1,A1,A2), l(A1,A2,_).
% :- a(R,N1,_,_), a(R,N2,_,_), N1 != N2.

:- a(R1,N,_,_), a(R2,N,_,_), R1 != R2.
:- a(R1,_,N,_), a(R2,_,N,_), R1 != R2.

:- C = #count { R : a(R,_,_,_), m(R,_,A1,A2) }, C != L, l(A1,A2,L).

total_dist(S) :- S = #sum { D : a(R,_,_,D) }.
#minimize { S : total_dist(S) }.

