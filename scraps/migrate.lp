% 0 { a(R,N1,N2) : link(_,A1,A2,N1,N2) } 1 :- m(R,_,A1,A2), l(A1,A2,_).
% % { a(R,N1,N2) : link(_,A1,A2,N1,N2) } :- m(R,_,A1,A2), l(A1,A2,_).
% % :- a(R,N1,_), a(R,N2,_), N1 != N2.

% :- a(R1,N,_), a(R2,N,_), R1 != R2.
% :- a(R1,_,N), a(R2,_,N), R1 != R2.

% :- C = #count { R : a(R,_,_), m(R,_,A1,A2) }, C != L, l(A1,A2,L).

% dist(R,D) :- m(R,N1,_,_), a(R,N2,_), node(N1,(X1,Y1),_), node(N2,(X2,Y2),_), D = |X1-X2| + |Y1-Y2|. 
% total_dist(S) :- S = #sum { D : dist(R,D) }.
% #minimize { S : total_dist(S) }.

% #show a/3.
% #show total_dist/1.

