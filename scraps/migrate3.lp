% 0 { a(R,N2,N3,|X1-X2|+|Y1-Y2|) : link(N2,(X2,Y2),N3,C3) } 1 :- m(R,(X1,Y1)).
{ a(R,N2,N3,|X1-X2|+|Y1-Y2|) : link(N2,(X2,Y2),N3,C3) } :- m(R,(X1,Y1)).

% 0 { a(R,N2,N3,|X1-X2|+|Y1-Y2|) : link(N3,C3,N2,(X2,Y2)) } 1 :- n(R,(X1,Y1)).
{ a(R,N2,N3,|X1-X2|+|Y1-Y2|) : link(N3,C3,N2,(X2,Y2)) } :- n(R,(X1,Y1)).

:- a(R,N1,_,_), a(R,N2,_,_), N1 != N2.

:- a(R1,N,_,_), a(R2,N,_,_), R1 != R2.
:- a(R1,_,N,_), a(R2,_,N,_), R1 != R2.

:- C = #count { R : a(R,_,_,_) }, C != L, l(L).

% total_dist(S) :- S = #sum { D : a(R,_,_,D) }, a(R,_,_,_).
total_dist(S) :- S = #sum { D : a(_,_,_,D) }.
#minimize { S : total_dist(S) }.

#show a/4.
#show total_dist/1.
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

% % 0 { a(R,N2,N3,|X1-X2|+|Y1-Y2|) : link(N2,(X2,Y2),N3,C3) } 1 :- m(R,(X1,Y1)).
% { a(R,N2,N3,|X1-X2|+|Y1-Y2|) : link(N2,(X2,Y2),N3,C3) } :- m(R,(X1,Y1)).
% :- a(R,N1,_,_), a(R,N2,_,_), N1 != N2.
% :- a(R1,N,_,_), a(R2,N,_,_), R1 != R2.
% :- a(R1,_,N,_), a(R2,_,N,_), R1 != R2.

% % 0 { b(R,N2,N3,|X1-X2|+|Y1-Y2|) : link(N3,C3,N2,(X2,Y2)) } 1 :- n(R,(X1,Y1)).
% { b(R,N2,N3,|X1-X2|+|Y1-Y2|) : link(N3,C3,N2,(X2,Y2)) } :- n(R,(X1,Y1)).
% :- b(R,N1,_,_), b(R,N2,_,_), N1 != N2.
% :- b(R1,N,_,_), b(R2,N,_,_), R1 != R2.
% :- b(R1,_,N,_), b(R2,_,N,_), R1 != R2.

% :- C = #count { R : a(R,_,_,_) }, D = #count { R : b(R,_,_,_) }, C + D != L, l(L).
% total_dist(S1+S2) :- S1 = #sum { D : a(_,_,_,D) }, S2 = #sum { D : b(_,_,_,D) }.

% #minimize { S : total_dist(S) }.

