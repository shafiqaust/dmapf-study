0 { a(R,N2,N3,|X1-X2|+|Y1-Y2|) : link(N2,N3), node(N2,(X2,Y2)) } 1 :- m(R,N1), node(N1,(X1,Y1)).
% { a(R,N2,N3,|X1-X2|+|Y1-Y2|) : link(N2,N3), node(N2,(X2,Y2)) } :- m(R,N1), node(N1,(X1,Y1)).
% :- a(R,N1,_,_), a(R,N2,_,_), N1 != N2.

:- a(R1,N,_,_), a(R2,N,_,_), R1 != R2.
:- a(R1,_,N,_), a(R2,_,N,_), R1 != R2.

:- C = #count { R : a(R,_,_,_) }, C != L, l(L).

% total_dist(S) :- S = #sum { D : a(R,_,_,D) }, a(R,_,_,_).
total_dist(S) :- S = #sum { D : a(_,_,_,D) }.
#minimize { S : total_dist(S) }.

#show a/4.
