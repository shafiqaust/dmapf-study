#program plan(t).
#external query(t).

% Generate moves for existing robots
% 0 { move(R,D,N2,t) : nextto(N1,N2,D) } 1 :- at(R,N1,t-1).
{ move(R,D,N2,t) : nextto(N1,N2,D) } :- at(R,N1,t-1).
:- move(R,D1,_,t), move(R,D2,_,t), D1 != D2.

% Force incoming robots to move in
% :- at(R,N,0), not node(N,_), not move(R,_,_,1), query(t).
:- at(R,N,0), edon(N), not move(R,_,_,1), query(t).

% Effects of moves
at(R,N2,t) :- at(R,N1,t-1), move(R,D,N2,t), nextto(N1,N2,D).

% Inertia
at(R,N,t) :- at(R,N,t-1), not move(R,_,_,t).

% Prevent edge collision
moveto(N1,N2,t) :- at(R,N1,t-1), move(R,D,N2,t), nextto(N1,N2,D).
:- moveto(N1,N2,t), moveto(N2,N1,t).

% Prevent vertex collision
:- { at(_,N,t) } > 1, node(N).

% Goal checking
reached(t) :- at(R,N,t) : goal(R,N).
:- query(t), not reached(t).

% #show.
% #show (R,D,N,T) : move(R,D,N,T).
#show move/4.