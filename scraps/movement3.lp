#program p(t).
#external q(t).
{ m(R,D,N2,t) : x(N1,N2,D) } :- r(R,N1,t-1).
:- m(R,D1,_,t), m(R,D2,_,t), D1 != D2.
:- r(R,N,0), o(N,_), not m(R,_,_,1), q(t).
r(R,N2,t) :- r(R,N1,t-1), m(R,D,N2,t), x(N1,N2,D).
r(R,N,t) :- r(R,N,t-1), not m(R,_,_,t).
w(N1,N2,t) :- r(R,N1,t-1), m(R,D,N2,t), x(N1,N2,D).
:- w(N1,N2,t), w(N2,N1,t).
:- { r(_,N,t) } > 1, i(N,_).
g(t) :- r(R,N,t) : g(R,N).
:- q(t), not g(t).
:- q(t), g(t), r(R,N,t), c(N), not g(R,N).
#show m/4.

%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
#script (python)
import clingo
from clingo.symbol import Number

def main(prg):
  prg.ground([("base", [])])

  for t in range(0, 100):
    print("t = {}".format(t))

    prg.ground([("p", [Number(t)])])
    atom = clingo.parse_term("q(" + str(t) + ")")
    prg.assign_external(atom, True)

    if str(prg.solve()) == "SAT":
      prg.release_external(atom)
      break

    prg.release_external(atom)
#end.
