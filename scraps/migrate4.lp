% 1 { o(R,N2,N3,|X1-X2|+|Y1-Y2|) : l(N2,(X2,Y2),N3,C3) } 1 :- a(R,(X1,Y1)).
% 0 { o(R,N2,N3,|X1-X2|+|Y1-Y2|) : l(N2,(X2,Y2),N3,C3) } 1 :- b(R,(X1,Y1)).

% 1 { i(R,N2,N3,|X1-X2|+|Y1-Y2|) : l(N3,C3,N2,(X2,Y2)) } 1 :- c(R,(X1,Y1)).
% 0 { i(R,N2,N3,|X1-X2|+|Y1-Y2|) : l(N3,C3,N2,(X2,Y2)) } 1 :- d(R,(X1,Y1)).

% % { o(R,N2,N3,|X1-X2|+|Y1-Y2|) : l(N2,(X2,Y2),N3,C3) } :- b(R,(X1,Y1)).
% % :- o(R,N1,_,_), o(R,N2,_,_), N1 != N2.
% % { i(R,N2,N3,|X1-X2|+|Y1-Y2|) : l(N3,C3,N2,(X2,Y2)) } :- d(R,(X1,Y1)).
