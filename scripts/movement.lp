%% Movement planning program
#program p(t).
#external q(t).
{m(R,D,t):d(D)}1:-r(R),t>0.
a(R,C',t):-a(R,C,t-1),m(R,D,t),x(C,C',D).
:-m(R,D,t),a(R,C,t-1),not x(C,_,D).
a(R,C,t):-a(R,C,t-1),not m(R,_,t).
w(C,C',t):-a(R,C,t-1),m(R,D,t),x(C,C',D).
:-w(C,C',t),w(C',C,t).
:-{a(_,C,t)}>1,i(C).
g(t):-a(R,C,t):g(r(R),C).
:-not g(t),q(t).
:-g(t),a(R,C,t),c(C),not g(r(R),C),q(t).
#show m/3.

#script (python)
import clingo
from clingo.symbol import Number

def main(prg):
  prg.ground([("base", [])])

  # t should start from 1 if there are robots that start at time step 1 (i.e., immigrating robots)
  for t in range(1,100):
    print("t = {}".format(t))
    prg.ground([("p", [Number(t)])])

    atom = clingo.parse_term("q(" + str(t) + ")")
    prg.assign_external(atom, True)

    if str(prg.solve()) == "SAT":
      break

    prg.release_external(atom)
#end.
